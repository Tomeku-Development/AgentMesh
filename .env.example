# FoxMQ Broker
FOXMQ_HOST=127.0.0.1
FOXMQ_PORT=1883

# Agent Configuration
MESH_AGENT_ROLE=buyer
MESH_AGENT_ID=auto
MESH_INITIAL_BALANCE=10000
MESH_CAPABILITIES=electronics,batteries
MESH_LOG_LEVEL=INFO

# Scenario
MESH_SCENARIO=electronics

# Bridge
BRIDGE_WS_PORT=8080
BRIDGE_MQTT_HOST=foxmq-node1
BRIDGE_MQTT_PORT=1883

# Dashboard
VITE_WS_URL=ws://localhost:8080

# ── Platform (SaaS) ──────────────────────────────────
PLATFORM_DATABASE_URL=postgresql+asyncpg://mesh:mesh@localhost:5432/mesh_platform
PLATFORM_SECRET_KEY=change-me-in-production-use-64-char-random
PLATFORM_MQTT_HOST=127.0.0.1
PLATFORM_MQTT_PORT=1883

# Xendit (fiat payments - IDR, PHP, THB, VND, MYR)
PLATFORM_XENDIT_SECRET_KEY=
PLATFORM_XENDIT_WEBHOOK_TOKEN=

# Cryptomus (crypto payments - BTC, ETH, USDT, SOL, 150+ tokens)
PLATFORM_CRYPTOMUS_MERCHANT_ID=
PLATFORM_CRYPTOMUS_API_KEY=
