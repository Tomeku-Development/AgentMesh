FROM python:3.11-slim

WORKDIR /app

COPY mesh/ /app/mesh/
COPY bridge/ /app/bridge/
COPY mesh/pyproject.toml /app/mesh/pyproject.toml

RUN pip install --no-cache-dir paho-mqtt pydantic pydantic-settings PyNaCl websockets

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

CMD ["python", "-m", "mesh.cli", "--help"]
