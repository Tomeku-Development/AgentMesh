{
  "buildCommand": "cd dashboard && npm install && npm run build",
  "outputDirectory": "dashboard/build",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/ws/:path*", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4",
      "maxDuration": 60
    }
  }
}
